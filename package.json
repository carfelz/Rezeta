{
  "name": "rezeta",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepare": "husky",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "pnpm --filter @rezeta/db migrate:dev",
    "db:seed": "pnpm --filter @rezeta/db seed && tsx --env-file=.env tools/seed-dev-users.ts",
    "seed:dev-users": "tsx --env-file=.env tools/seed-dev-users.ts",
    "db:reset": "pnpm --filter @rezeta/db migrate:reset",
    "db:studio": "pnpm --filter @rezeta/db studio",
    "demo:data": "tsx tools/create-demo-data.ts",
    "seed:templates": "tsx tools/seed-protocol-templates.ts",
    "emulator": "firebase emulators:start --only auth --project rezeta-dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "tsx": "^4.19.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@nestjs/core",
      "esbuild",
      "protobufjs"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
