VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_API_URL=

# ── Local dev: Firebase Auth emulator ────────────────────────────────────────
# Copy these into .env.development.local (not .env.example) for emulator mode.
# Start the emulator first: pnpm emulator
# VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# VITE_STUB_AUTH=true   # set to skip Firebase entirely (API must have STUB_AUTH=true too)
