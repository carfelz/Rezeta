# Supabase pooler URL (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Supabase direct URL (port 5432) — used only by prisma migrate
DIRECT_URL=postgresql://postgres.[project]:[password]@db.[project].supabase.co:5432/postgres
FIREBASE_PROJECT_ID=rezeta-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@rezeta-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=
GCS_BUCKET=rezeta-dev-uploads
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
