{
  "name": "@rezeta/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:no-auth": "STUB_AUTH=true tsx watch src/main.ts",
    "dev": "STUB_AUTH=false tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 vitest run test/auth.integration.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^8.1.1",
    "@rezeta/db": "workspace:*",
    "@rezeta/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "firebase-admin": "^12.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.26",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.0.0"
  }
}
