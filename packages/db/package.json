{
  "name": "@rezeta/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./generated/index.js",
  "exports": {
    ".": {
      "import": "./generated/index.js",
      "require": "./generated/index.js",
      "default": "./generated/index.js",
      "types": "./generated/index.d.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "migrate:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0"
  }
}
