generator client {
  provider        = "prisma-client-js"
  output          = "../generated"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto]
}

// ─────────────────────────────────────────────
// Foundation
// ─────────────────────────────────────────────

model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String?   @db.VarChar(200)
  type      String    @default("solo") @db.VarChar(50) // solo | practice | clinic | enterprise
  plan      String    @default("free") @db.VarChar(50) // free | solo | practice | clinic
  country   String    @default("DO") @db.VarChar(10)
  language  String    @default("es") @db.VarChar(10)
  timezone  String    @default("America/Santo_Domingo") @db.VarChar(60)
  seededAt  DateTime? @map("seeded_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  users               User[]
  locations           Location[]
  patients            Patient[]
  appointments        Appointment[]
  consultations       Consultation[]
  prescriptions       Prescription[]
  invoices            Invoice[]
  protocols           Protocol[]
  protocolTemplates   ProtocolTemplate[]
  protocolTypes       ProtocolType[]
  protocolVersions    ProtocolVersion[]
  protocolUsages      ProtocolUsage[]
  protocolSuggestions ProtocolSuggestion[]
  imagingOrders       ImagingOrder[]
  labOrders           LabOrder[]
  auditLogs           AuditLog[]
  attachments         Attachment[]

  @@map("tenants")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  firebaseUid   String    @unique @map("firebase_uid") @db.VarChar(128)
  email         String    @db.VarChar(320)
  fullName      String?   @map("full_name") @db.VarChar(200)
  role          String    @default("owner") @db.VarChar(50) // owner | doctor
  specialty     String?   @db.VarChar(100)
  licenseNumber String?   @map("license_number") @db.VarChar(100)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  doctorLocations       DoctorLocation[]
  scheduleBlocks        ScheduleBlock[]
  scheduleExceptions    ScheduleException[]
  ownedPatients         Patient[]               @relation("PatientOwner")
  appointments          Appointment[]
  consultations         Consultation[]
  signedConsultations   Consultation[]          @relation("ConsultationSigner")
  amendments            ConsultationAmendment[]
  prescriptions         Prescription[]
  invoices              Invoice[]
  imagingOrders         ImagingOrder[]
  labOrders             LabOrder[]
  protocols             Protocol[]              @relation("ProtocolCreator")
  protocolTemplates     ProtocolTemplate[]
  protocolVersions      ProtocolVersion[]       @relation("VersionCreator")
  approvedVersions      ProtocolVersion[]       @relation("VersionApprover")
  protocolUsages        ProtocolUsage[]
  auditLogs             AuditLog[]
  uploadedAttachments   Attachment[]

  @@index([tenantId])
  @@index([firebaseUid])
  @@index([tenantId, deletedAt])
  @@map("users")
}

model Location {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  name             String    @db.VarChar(200)
  address          String?   @db.VarChar(500)
  city             String?   @db.VarChar(100)
  phone            String?   @db.VarChar(30)
  isOwned          Boolean   @default(false) @map("is_owned")
  notes            String?   @db.Text
  commissionPercent Decimal  @default(0) @map("commission_percent") @db.Decimal(5, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  doctorLocations    DoctorLocation[]
  scheduleBlocks     ScheduleBlock[]
  scheduleExceptions ScheduleException[]
  appointments       Appointment[]
  consultations      Consultation[]
  invoices           Invoice[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("locations")
}

model DoctorLocation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  locationId      String   @map("location_id") @db.Uuid
  consultationFee Decimal  @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  commissionPct   Decimal  @default(0) @map("commission_pct") @db.Decimal(5, 2)
  roomOrOffice    String?  @map("room_or_office") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([userId, locationId])
  @@index([userId])
  @@index([locationId])
  @@map("doctor_locations")
}

model ScheduleBlock {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  locationId      String   @map("location_id") @db.Uuid
  dayOfWeek       Int      @map("day_of_week") // 0=Sunday … 6=Saturday
  startTime       String   @map("start_time") @db.VarChar(8) // HH:MM:SS
  endTime         String   @map("end_time") @db.VarChar(8)
  slotDurationMin Int      @default(30) @map("slot_duration_min")
  createdAt       DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([userId, locationId])
  @@map("schedule_blocks")
}

model ScheduleException {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  date       DateTime @db.Date
  startTime  String?  @map("start_time") @db.VarChar(8)
  endTime    String?  @map("end_time") @db.VarChar(8)
  type       String   @db.VarChar(50) // blocked | available
  reason     String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([userId, date])
  @@index([locationId, date])
  @@map("schedule_exceptions")
}

// ─────────────────────────────────────────────
// Clinical
// ─────────────────────────────────────────────

model Patient {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  ownerUserId      String    @map("owner_user_id") @db.Uuid
  documentType     String?   @map("document_type") @db.VarChar(20) // cedula | passport | rnc
  documentNumber   String?   @map("document_number") @db.VarChar(30)
  firstName        String    @map("first_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  sex              String?   @db.VarChar(10) // male | female | other
  phone            String?   @db.VarChar(30)
  email            String?   @db.VarChar(320)
  address          String?   @db.VarChar(500)
  bloodType        String?   @map("blood_type") @db.VarChar(5)
  allergies        Json      @default("[]")
  chronicConditions Json     @default("[]") @map("chronic_conditions")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  owner         User           @relation("PatientOwner", fields: [ownerUserId], references: [id])
  appointments  Appointment[]
  consultations Consultation[]
  prescriptions Prescription[]
  invoices      Invoice[]
  imagingOrders ImagingOrder[]
  labOrders     LabOrder[]
  protocolUsages ProtocolUsage[]

  @@index([tenantId])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, deletedAt])
  @@map("patients")
}

model Appointment {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  patientId  String    @map("patient_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  locationId String    @map("location_id") @db.Uuid
  startsAt   DateTime  @map("starts_at")
  endsAt     DateTime  @map("ends_at")
  status     String    @default("scheduled") @db.VarChar(30) // scheduled | completed | cancelled | no_show
  reason     String?   @db.VarChar(500)
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       User          @relation(fields: [userId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  consultation Consultation?

  @@index([tenantId])
  @@index([tenantId, userId, startsAt])
  @@index([tenantId, locationId, startsAt])
  @@index([tenantId, patientId])
  @@index([tenantId, deletedAt])
  @@map("appointments")
}

model Consultation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  appointmentId String?   @unique @map("appointment_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  locationId    String    @map("location_id") @db.Uuid
  status        String    @default("draft") @db.VarChar(20) // draft | signed
  signedAt      DateTime? @map("signed_at")
  signedBy      String?   @map("signed_by") @db.Uuid
  contentHash   String?   @map("content_hash") @db.VarChar(64)
  chiefComplaint String?  @map("chief_complaint") @db.Text
  subjective    String?   @db.Text
  objective     String?   @db.Text
  assessment    String?   @db.Text
  plan          String?   @db.Text
  vitals        Json?
  diagnoses     Json      @default("[]")
  protocolsApplied String[]  @default([]) @map("protocols_applied")
  consultedAt      DateTime  @default(now()) @map("consulted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  appointment   Appointment?            @relation(fields: [appointmentId], references: [id])
  patient       Patient                 @relation(fields: [patientId], references: [id])
  doctor        User                    @relation(fields: [userId], references: [id])
  signer        User?                   @relation("ConsultationSigner", fields: [signedBy], references: [id])
  location      Location                @relation(fields: [locationId], references: [id])
  amendments    ConsultationAmendment[]
  prescriptions Prescription[]
  imagingOrders ImagingOrder[]
  labOrders     LabOrder[]
  invoice       Invoice?
  protocolUsages ProtocolUsage[]

  @@index([tenantId])
  @@index([tenantId, userId, consultedAt])
  @@index([tenantId, patientId])
  @@index([tenantId, deletedAt])
  @@map("consultations")
}

model ConsultationAmendment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consultationId  String   @map("consultation_id") @db.Uuid
  amendmentNumber Int      @map("amendment_number")
  reason          String   @db.VarChar(1000)
  content         Json
  amendedBy       String   @map("amended_by") @db.Uuid
  amendedAt       DateTime @default(now()) @map("amended_at")
  signedAt        DateTime? @map("signed_at")

  consultation Consultation @relation(fields: [consultationId], references: [id])
  author       User         @relation(fields: [amendedBy], references: [id])

  @@unique([consultationId, amendmentNumber])
  @@index([consultationId])
  @@map("consultation_amendments")
}

model Prescription {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  consultationId String?   @map("consultation_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  groupTitle     String?   @map("group_title") @db.VarChar(200)
  groupOrder     Int       @default(1) @map("group_order")
  items          Json      // legacy JSON blob kept for backward compat
  status         String    @default("draft") @db.VarChar(20) // draft | signed
  signedAt       DateTime? @map("signed_at")
  pdfUrl         String?   @map("pdf_url") @db.VarChar(2048)
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  consultation      Consultation?      @relation(fields: [consultationId], references: [id])
  patient           Patient            @relation(fields: [patientId], references: [id])
  doctor            User               @relation(fields: [userId], references: [id])
  prescriptionItems PrescriptionItem[]

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([consultationId, groupOrder])
  @@index([tenantId, deletedAt])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prescriptionId String  @map("prescription_id") @db.Uuid
  drug           String  @db.VarChar(300)
  dose           String  @db.VarChar(200)
  route          String  @db.VarChar(100)
  frequency      String  @db.VarChar(200)
  duration       String  @db.VarChar(200)
  notes          String? @db.Text
  source         String? @db.VarChar(200) // "protocol:blk_id:row_id" | "manual"
  sortOrder      Int     @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ─────────────────────────────────────────────
// Billing
// ─────────────────────────────────────────────

model Invoice {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  patientId        String    @map("patient_id") @db.Uuid
  consultationId   String?   @unique @map("consultation_id") @db.Uuid
  locationId       String    @map("location_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  invoiceNumber    String    @map("invoice_number") @db.VarChar(50)
  currency         String    @default("DOP") @db.VarChar(3)
  status           String    @default("draft") @db.VarChar(20) // draft | issued | paid | cancelled
  subtotal         Decimal   @db.Decimal(12, 2)
  tax              Decimal   @default(0) @db.Decimal(12, 2)
  total            Decimal   @db.Decimal(12, 2)
  commissionAmount Decimal   @default(0) @map("commission_amount") @db.Decimal(12, 2)
  commissionPercent Decimal  @default(0) @map("commission_percent") @db.Decimal(5, 2)
  netToDoctor      Decimal   @default(0) @map("net_to_doctor") @db.Decimal(12, 2)
  paymentMethod    String?   @map("payment_method") @db.VarChar(50)
  issuedAt         DateTime? @map("issued_at")
  paidAt           DateTime? @map("paid_at")
  dueDate          DateTime? @map("due_date") @db.Date
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  doctor       User          @relation(fields: [userId], references: [id])
  items        InvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, userId])
  @@index([tenantId, deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  description String  @db.VarChar(500)
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────────
// Protocols
// ─────────────────────────────────────────────

model ProtocolTemplate {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  templateKey        String?   @map("template_key") @db.VarChar(100) // unique slug for system templates
  name               String    @db.VarChar(300)
  description        String?   @db.Text
  suggestedSpecialty String?   @map("suggested_specialty") @db.VarChar(100)
  isSystem           Boolean   @default(false) @map("is_system") // true = global system template
  schema             Json
  isSeeded           Boolean   @default(false) @map("is_seeded")
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  creator       User?          @relation(fields: [createdBy], references: [id])
  protocolTypes ProtocolType[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("protocol_templates")
}

model ProtocolType {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  templateId String    @map("template_id") @db.Uuid
  name       String    @db.VarChar(200)
  isSeeded   Boolean   @default(false) @map("is_seeded")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  template  ProtocolTemplate @relation(fields: [templateId], references: [id])
  protocols Protocol[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, templateId])
  @@index([tenantId, deletedAt])
  @@map("protocol_types")
}

model Protocol {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  typeId           String    @map("type_id") @db.Uuid
  title            String    @db.VarChar(300)
  description      String?   @db.Text
  specialty        String?   @db.VarChar(100)
  tags             Json      @default("[]")
  status           String    @default("draft") @db.VarChar(20) // draft | active | archived
  visibility       String    @default("private") @db.VarChar(20) // private | practice | public
  currentVersionId String?   @map("current_version_id") @db.Uuid
  isFavorite       Boolean   @default(false) @map("is_favorite")
  metadata         Json?     // { auto_generated: bool, source_protocol_id: string }
  createdBy        String    @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  type        ProtocolType         @relation(fields: [typeId], references: [id])
  creator     User                 @relation("ProtocolCreator", fields: [createdBy], references: [id])
  versions    ProtocolVersion[]
  usages      ProtocolUsage[]
  suggestions ProtocolSuggestion[]

  @@index([tenantId])
  @@index([tenantId, typeId])
  @@index([tenantId, createdBy])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("protocols")
}

model ProtocolVersion {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  protocolId    String    @map("protocol_id") @db.Uuid
  versionNumber Int       @map("version_number")
  content       Json
  changeSummary String?   @map("change_summary") @db.VarChar(500)
  createdBy     String    @map("created_by") @db.Uuid
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  protocol Protocol        @relation(fields: [protocolId], references: [id])
  author   User            @relation("VersionCreator", fields: [createdBy], references: [id])
  approver User?           @relation("VersionApprover", fields: [approvedBy], references: [id])
  usages   ProtocolUsage[]

  @@unique([protocolId, versionNumber])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([protocolId])
  @@map("protocol_versions")
}

model ProtocolUsage {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  protocolId          String    @map("protocol_id") @db.Uuid
  protocolVersionId   String    @map("protocol_version_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  patientId           String?   @map("patient_id") @db.Uuid
  consultationId      String?   @map("consultation_id") @db.Uuid
  // Working copy — full editable snapshot of the protocol content at launch time
  content             Json      @default("{}")
  // Incremental modification log tracking every change made during this usage
  modifications       Json      @default("{}") @map("modifications")
  modificationSummary String?   @map("modification_summary") @db.VarChar(500)
  // Protocol chain support — parent usage that launched this one
  parentUsageId       String?   @map("parent_usage_id") @db.Uuid
  triggerBlockId      String?   @map("trigger_block_id") @db.VarChar(100)
  depth               Int       @default(0)
  status              String    @default("in_progress") @db.VarChar(20) // in_progress | completed | abandoned
  // Legacy field kept for backward compat with existing code
  checkedState        Json      @default("{}") @map("checked_state")
  completedAt         DateTime? @map("completed_at")
  appliedAt           DateTime  @default(now()) @map("applied_at")
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  protocol        Protocol        @relation(fields: [protocolId], references: [id])
  protocolVersion ProtocolVersion @relation(fields: [protocolVersionId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  patient         Patient?        @relation(fields: [patientId], references: [id])
  consultation    Consultation?   @relation(fields: [consultationId], references: [id])
  parentUsage     ProtocolUsage?  @relation("ProtocolChain", fields: [parentUsageId], references: [id])
  childUsages     ProtocolUsage[] @relation("ProtocolChain")

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([protocolId])
  @@index([userId])
  @@index([consultationId])
  @@index([parentUsageId])
  @@index([status])
  @@index([createdAt])
  @@map("protocol_usages")
}

model ProtocolSuggestion {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  protocolId           String    @map("protocol_id") @db.Uuid
  protocolVersionId    String    @map("protocol_version_id") @db.Uuid
  patternType          String    @map("pattern_type") @db.VarChar(100) // medication_dose_change | medication_added | medication_removed | step_skipped | imaging_added | lab_added | etc.
  patternData          Json      @map("pattern_data")
  suggestedChanges     Json      @map("suggested_changes")
  impactSummary        String    @map("impact_summary") @db.VarChar(500)
  occurrenceCount      Int       @map("occurrence_count")
  totalUses            Int       @map("total_uses")
  occurrencePercentage Decimal   @map("occurrence_percentage") @db.Decimal(5, 2)
  status               String    @default("pending") @db.VarChar(20) // pending | applied | dismissed
  appliedAt            DateTime? @map("applied_at")
  dismissedAt          DateTime? @map("dismissed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  protocol Protocol @relation(fields: [protocolId], references: [id])

  @@index([protocolId, status])
  @@index([tenantId])
  @@index([createdAt])
  @@map("protocol_suggestions")
}

model ImagingOrder {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  consultationId       String    @map("consultation_id") @db.Uuid
  patientId            String    @map("patient_id") @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  groupTitle           String?   @map("group_title") @db.VarChar(200)
  groupOrder           Int       @default(1) @map("group_order")
  studyType            String    @map("study_type") @db.VarChar(300)
  indication           String    @db.VarChar(500)
  urgency              String    @default("routine") @db.VarChar(20) // routine | urgent | stat
  contrast             Boolean   @default(false)
  fastingRequired      Boolean   @default(false) @map("fasting_required")
  specialInstructions  String?   @map("special_instructions") @db.Text
  source               String?   @db.VarChar(200) // "protocol:blk_id:order_id" | "manual"
  status               String    @default("draft") @db.VarChar(20) // draft | signed
  signedAt             DateTime? @map("signed_at")
  pdfUrl               String?   @map("pdf_url") @db.VarChar(2048)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  consultation Consultation @relation(fields: [consultationId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  doctor       User         @relation(fields: [userId], references: [id])

  @@index([consultationId, groupOrder])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("imaging_orders")
}

model LabOrder {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  consultationId      String    @map("consultation_id") @db.Uuid
  patientId           String    @map("patient_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  groupTitle          String?   @map("group_title") @db.VarChar(200)
  groupOrder          Int       @default(1) @map("group_order")
  testName            String    @map("test_name") @db.VarChar(300)
  testCode            String?   @map("test_code") @db.VarChar(50)
  indication          String    @db.VarChar(500)
  urgency             String    @default("routine") @db.VarChar(20) // routine | urgent | stat
  fastingRequired     Boolean   @default(false) @map("fasting_required")
  sampleType          String    @map("sample_type") @db.VarChar(50) // blood | urine | stool | other
  specialInstructions String?   @map("special_instructions") @db.Text
  source              String?   @db.VarChar(200)
  status              String    @default("draft") @db.VarChar(20) // draft | signed
  signedAt            DateTime? @map("signed_at")
  pdfUrl              String?   @map("pdf_url") @db.VarChar(2048)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  consultation Consultation @relation(fields: [consultationId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  doctor       User         @relation(fields: [userId], references: [id])

  @@index([consultationId, groupOrder])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("lab_orders")
}

// ─────────────────────────────────────────────
// Cross-cutting
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(50) // create | update | delete | sign | amend | archive
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Attachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  fileUrl    String   @map("file_url") @db.VarChar(2048)
  fileName   String   @map("file_name") @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  sizeBytes  Int      @map("size_bytes")
  uploadedBy String   @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId, entityType, entityId])
  @@map("attachments")
}
