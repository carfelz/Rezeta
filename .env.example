# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rezeta:rezeta@localhost:5432/rezeta_dev

# ── Firebase Admin (API server) ─────────────────────────────────────────────
# Get these from Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative: set FIREBASE_ADMIN_KEY to the full JSON blob (useful for Cloud Run secrets)
# FIREBASE_ADMIN_KEY=

# ── Firebase Client (web app) ────────────────────────────────────────────────
# Get these from Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ── API server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# ── Storage ──────────────────────────────────────────────────────────────────
GCS_BUCKET=rezeta-dev-uploads

# ── Web app ──────────────────────────────────────────────────────────────────
# Leave empty to use the Vite proxy (recommended for local dev)
VITE_API_URL=
