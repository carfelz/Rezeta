# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rezeta:rezeta@localhost:5432/rezeta_dev

# ── Firebase Admin (API server) ─────────────────────────────────────────────
# For local dev: use Firebase emulator values (see tools/README.md)
FIREBASE_PROJECT_ID=rezeta-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@rezeta-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=

# ── Firebase Client (web app) ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rezeta-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rezeta-dev

# ── API server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# ── Storage ──────────────────────────────────────────────────────────────────
GCS_BUCKET=rezeta-dev-uploads

# ── Web app ──────────────────────────────────────────────────────────────────
# Leave empty to use the Vite proxy (recommended for local dev)
VITE_API_URL=
